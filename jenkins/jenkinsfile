pipeline {
    agent {
        node {label 'node1'}
    }
    stages{
        stage('pull') {
            steps {
                git 'https://github.com/adityaithape7192-ops/studentdata.git'
                echo " pull successful"
            }
        }
        stage('Build') {
            steps {
                sh '/opt/apache-maven-3.9.15/bin/mvn clean package'
                echo " building successful"
            }
        }
        stage('Test') {
            steps {
                echo " testing successful"
            }
        }
        stage('Deploy') {
            steps {
                echo "deployment successful"
            }
        }
    }
}