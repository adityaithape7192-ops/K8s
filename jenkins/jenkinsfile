pipeline {
    agent {
        node {label 'node1'}
    }
    stages{
        stage('pull') {
            steps {
                git 'https://github.com/adityaithape7192-ops/Sport-shop-project-using-docker.git'
                echo " pull successful"
            }
        }
        stage('Build') {
            steps {
                echo " building successful"
            }
        }
        stage('Test') {
            steps {
                echo " testing successful"
            }
        }
        stage('Deploy') {
            steps {
                echo "deployment successful"
            }
        }
    }
}